{
  "identifier": "default",
  "description": "Default capability for the sample app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "^https?://.*" },
        { "url": "^[a-zA-Z]:\\\\.*" },
        { "url": "^/.*" }
      ]
    }
  ]
}
